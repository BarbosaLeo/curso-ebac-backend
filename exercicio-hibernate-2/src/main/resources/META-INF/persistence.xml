<persistence version="2.0" xmlns="http://java.sun.com/xml/ns/persistence" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://java.sun.com/xml/ns/persistence http://java.sun.com/xml/ns/persistence/persistence_2_0.xsd">
  <persistence-unit name="com.barbosaleo.projeto_hibernate.teste">
    <description>
            Persistence unit for the Jakarta Persistence tutorial of the Hibernate Getting Started Guide
        </description>
    <class>com.barbosaleo.domain.Carro</class>
    <class>com.barbosaleo.domain.Acessorio</class>
    <class>com.barbosaleo.domain.Marca</class>
    <properties>
      <!-- Database connection settings -->
      <property name="jakarta.persistence.jdbc.url" value="jdbc:postgresql://localhost:15432/db_teste"/>
      <property name="jakarta.persistence.jdbc.user" value="postgres"/>
      <property name="jakarta.persistence.jdbc.driver" value="org.postgresql.Driver"/>
      <property name="jakarta.persistence.jdbc.password" value="admin"/>
      <!-- Automatically export the schema -->
      <property name="jakarta.persistence.schema-generation.database.action" value="create"/>
      <!-- Echo all executed SQL to console -->
      <property name="hibernate.show_sql" value="true"/>
      <property name="hibernate.format_sql" value="true"/>
      <property name="hibernate.highlight_sql" value="true"/>
    </properties>
  </persistence-unit>
</persistence>
